  <CheatEntries>
    <CheatEntry>
      <ID>5</ID>
      <Description>"Inf items"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
//code from here to '[DISABLE]' will be used to enable the cheat
alloc(newmem,2048,"GameAssembly.dll"+2C9BC87) 
label(returnhere)
label(originalcode)
label(exit)

newmem: //this is allocated memory, you have read,write,execute access
//place your code here
cmp dword ptr [rsp+8],GameAssembly.dll+53B50E//Item Condition caller
je exit
cmp dword ptr [rsp+8],GameAssembly.dll+EFED38//stackable items??

je exit

originalcode:
mov ebx,[rbx]
mov rcx,[rax+20]
jmp returnhere

exit:
mov [rbx],(int)9999
mov ebx,[rbx]
mov rcx,[rax+20]
jmp returnhere

"GameAssembly.dll"+2C9BC87:
jmp newmem
nop
returnhere:


 
 
[DISABLE]
//code from here till the end of the code will be used to disable the cheat
dealloc(newmem)
"GameAssembly.dll"+2C9BC87:
db 8B 1B 48 8B 48 20
//mov ebx,[rbx]
//mov rcx,[rax+20]
</AssemblerScript>
    </CheatEntry>
    <CheatEntry>
      <ID>10</ID>
      <Description>"0 Item Weight"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]

alloc(newmem,128,GameAssembly.dll+845718)
label(return_here)

newmem:
  // Force return value = 0
  xor rax,rax          // for integer/struct backing
  pxor xmm0,xmm0       // for float-based return, safe either way

  // Recreate original epilogue:
  add rsp,70
  pop r15
  pop r14
  pop rbx
  ret

GameAssembly.dll+845718:
  jmp newmem
  nop                  // pad to overwrite at least 5 bytes cleanly

return_here:

[DISABLE]

GameAssembly.dll+845718:
  // restore original bytes
  db 48 83 C4 70 41 5F 41 5E 5B C3

dealloc(newmem)

</AssemblerScript>
    </CheatEntry>
